import 'package:get/get.dart';


{enum_code}
class {prefix}MainTabLogic extends GetxController {
  final currentIndex = 0.obs;

  void switchTab(int index) {
    if (index == currentIndex.value) return; // 已在当前 tab，不重复切换
    currentIndex.value = index;
  }

  void switchTo(MainTab tab) => switchTab(tab.index);
}

mixin {prefix}MainTabLogicMixin {
  late final {prefix}MainTabLogic logic = Get.put({prefix}MainTabLogic());
}