part of 'route_navigator.dart';

PageJumpRouteAction routeActionHandler = (event) => _getToNamed(event.target, arguments: event.arguments);

PageJumpUnhandledUrlHandler unhandledNativeUrlHandler = (url, uri, object) {
  logD('jump by UnhandledNativeUrlHandler: $url');
  return Future.value();
};

PageJumpUnhandledUrlHandler unhandledUrlHandler = (url, uri, object) {
  logD('jump by unhandledUrlHandler: $url');
  return launchUrl(Uri.parse(url));
};

AuthHandler authHandler = ({onPassed, onCanceled, authType}) {
  authService.checkingAuth(onPassed: onPassed, onCanceled: onCanceled, requiredChecks: authType);
};

final PageJumpConfig webJumpConfig = PageJumpConfig(
  "/web",
  parser: (url, parameters) {
    if (url.startsWith('http') || url.startsWith('https')) {
      return {'url': url};
    } else {
      return parameters;
    }
  },
  action: (event) {
    String? webUrl = parseString(event.arguments, 'url');
    return nav.goWebPage(webUrl ?? '');
  },
);

/// 跳转配置, 不受白名单的影响
final Map<String, PageJumpConfig> jumpConfigs = {
  /// web(scheme://web?url=%s)
  "web": webJumpConfig,
};